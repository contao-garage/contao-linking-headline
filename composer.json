{
    "name": "contao-garage/contao-linking-headline",
    "description": "Contao 5 CMS module providing a headline element linking to a target url",
    "type": "contao-bundle",
    "keywords": ["contao bundle", "linking headline", "content element"],
    "support": {
        "issues": "https://github.com/contao-garage/contao-linking-headline/issues",
        "source": "https://github.com/contao-garage/contao-linking-headline"
    },
    "homepage": "https://contao-garage.de",
    "license": "MIT",
    "authors": [
        {
            "name": "Martin Schumann",
            "homepage": "https://github.com/martinschumann"
        }
    ],
    "require": {
        "php": "^8.2",
        "contao/core-bundle": "^5.3"
    },
    "autoload": {
        "psr-4": {
            "ContaoGarage\\LinkingHeadline\\": "src/"
        },
        "classmap": [
            "contao/"
        ],
        "exclude-from-classmap": [
            "contao/dca/",
            "contao/languages/",
            "contao/templates/"
        ]
    },
    "extra": {
        "contao-manager-plugin": "ContaoGarage\\LinkingHeadline\\ContaoManager\\Plugin"
    },
    "require-dev": {
        "contao/easy-coding-standard": "^6.13",
        "contao/rector": "^1.3"
    },
    "config": {
        "allow-plugins": {
            "contao-components/installer": true,
            "php-http/discovery": true,
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
